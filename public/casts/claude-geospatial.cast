[3.0, "o", "\u001b[1;36mв ‹\u001b[0m Thinking...\r\n"]
[3.5, "o", "\u001b[A\u001b[2K"]
[3.5, "o", "\u001b[1;36mв ™\u001b[0m Planning approach...\r\n"]
[4.0, "o", "\u001b[A\u001b[2K"]
[4.0, "o", "\r\n\u001b[1;36mв”Њв”Ђ\u001b[0m I'll search Planetary Computer for Sentinel-2 imagery over Austin,\r\n"]
[4.1, "o", "\u001b[1;36mв”‚\u001b[0m  load the bands with odc.stac, compute NDVI, and save as a COG.\r\n"]
[4.2, "o", "\u001b[1;36mв””в”Ђ\u001b[0m\r\n\r\n"]
[4.6, "o", "\u001b[1;33m  Write\u001b[0m \u001b[4mndvi_austin.py\u001b[0m\r\n\r\n"]
[5.0, "o", "\u001b[38;5;245m  1 в”‚\u001b[0m \u001b[38;5;203mimport\u001b[0m \u001b[38;5;117mrasterio\u001b[0m\r\n"]
[5.1, "o", "\u001b[38;5;245m  2 в”‚\u001b[0m \u001b[38;5;203mimport\u001b[0m \u001b[38;5;117mnumpy\u001b[0m \u001b[38;5;203mas\u001b[0m \u001b[38;5;117mnp\u001b[0m\r\n"]
[5.2, "o", "\u001b[38;5;245m  3 в”‚\u001b[0m \u001b[38;5;203mfrom\u001b[0m \u001b[38;5;117mpystac_client\u001b[0m \u001b[38;5;203mimport\u001b[0m \u001b[38;5;117mClient\u001b[0m\r\n"]
[5.3, "o", "\u001b[38;5;245m  4 в”‚\u001b[0m \u001b[38;5;203mimport\u001b[0m \u001b[38;5;117modc.stac\u001b[0m\r\n"]
[5.4, "o", "\u001b[38;5;245m  5 в”‚\u001b[0m \u001b[38;5;203mimport\u001b[0m \u001b[38;5;117mplanetary_computer\u001b[0m\r\n"]
[5.5, "o", "\u001b[38;5;245m  6 в”‚\u001b[0m\r\n"]
[5.6, "o", "\u001b[38;5;245m  7 в”‚\u001b[0m \u001b[38;5;102m# Search Planetary Computer for Sentinel-2 over UT Austin\u001b[0m\r\n"]
[5.7, "o", "\u001b[38;5;245m  8 в”‚\u001b[0m catalog = Client.open(\r\n"]
[5.8, "o", "\u001b[38;5;245m  9 в”‚\u001b[0m     \u001b[38;5;186m\"https://planetarycomputer.microsoft.com/api/stac/v1\"\u001b[0m\r\n"]
[5.9, "o", "\u001b[38;5;245m 10 в”‚\u001b[0m )\r\n"]
[6.0, "o", "\u001b[38;5;245m 11 в”‚\u001b[0m search = catalog.search(\r\n"]
[6.1, "o", "\u001b[38;5;245m 12 в”‚\u001b[0m     collections=[\u001b[38;5;186m\"sentinel-2-l2a\"\u001b[0m],\r\n"]
[6.2, "o", "\u001b[38;5;245m 13 в”‚\u001b[0m     bbox=[\u001b[38;5;186m-97.745, 30.28, -97.73, 30.295\u001b[0m],\r\n"]
[6.3, "o", "\u001b[38;5;245m 14 в”‚\u001b[0m     datetime=\u001b[38;5;186m\"2024-06-01/2024-08-31\"\u001b[0m,\r\n"]
[6.4, "o", "\u001b[38;5;245m 15 в”‚\u001b[0m     query={\u001b[38;5;186m\"eo:cloud_cover\"\u001b[0m: {\u001b[38;5;186m\"lt\"\u001b[0m: \u001b[38;5;186m10\u001b[0m}},\r\n"]
[6.5, "o", "\u001b[38;5;245m 16 в”‚\u001b[0m )\r\n"]
[6.6, "o", "\u001b[38;5;245m 17 в”‚\u001b[0m items = search.item_collection()\r\n"]
[6.7, "o", "\u001b[38;5;245m 18 в”‚\u001b[0m\r\n"]
[6.8, "o", "\u001b[38;5;245m 19 в”‚\u001b[0m \u001b[38;5;102m# Load NIR (B08) and Red (B04) bands\u001b[0m\r\n"]
[6.9, "o", "\u001b[38;5;245m 20 в”‚\u001b[0m signed = [planetary_computer.sign(i) \u001b[38;5;203mfor\u001b[0m i \u001b[38;5;203min\u001b[0m items]\r\n"]
[7.0, "o", "\u001b[38;5;245m 21 в”‚\u001b[0m ds = odc.stac.load(\r\n"]
[7.1, "o", "\u001b[38;5;245m 22 в”‚\u001b[0m     signed, bands=[\u001b[38;5;186m\"B04\"\u001b[0m, \u001b[38;5;186m\"B08\"\u001b[0m],\r\n"]
[7.2, "o", "\u001b[38;5;245m 23 в”‚\u001b[0m     resolution=\u001b[38;5;186m10\u001b[0m,\r\n"]
[7.3, "o", "\u001b[38;5;245m 24 в”‚\u001b[0m     bbox=[\u001b[38;5;186m-97.745, 30.28, -97.73, 30.295\u001b[0m],\r\n"]
[7.4, "o", "\u001b[38;5;245m 25 в”‚\u001b[0m )\r\n"]
[7.5, "o", "\u001b[38;5;245m 26 в”‚\u001b[0m\r\n"]
[7.6, "o", "\u001b[38;5;245m 27 в”‚\u001b[0m \u001b[38;5;102m# Compute NDVI = (NIR - Red) / (NIR + Red)\u001b[0m\r\n"]
[7.7, "o", "\u001b[38;5;245m 28 в”‚\u001b[0m nir = ds[\u001b[38;5;186m\"B08\"\u001b[0m].isel(time=\u001b[38;5;186m0\u001b[0m).values.astype(\u001b[38;5;186m\"float32\"\u001b[0m)\r\n"]
[7.8, "o", "\u001b[38;5;245m 29 в”‚\u001b[0m red = ds[\u001b[38;5;186m\"B04\"\u001b[0m].isel(time=\u001b[38;5;186m0\u001b[0m).values.astype(\u001b[38;5;186m\"float32\"\u001b[0m)\r\n"]
[7.9, "o", "\u001b[38;5;245m 30 в”‚\u001b[0m ndvi = (nir - red) / (nir + red + \u001b[38;5;186m1e-10\u001b[0m)\r\n"]
[8.0, "o", "\u001b[38;5;245m 31 в”‚\u001b[0m\r\n"]
[8.1, "o", "\u001b[38;5;245m 32 в”‚\u001b[0m \u001b[38;5;102m# Save as Cloud-Optimized GeoTIFF\u001b[0m\r\n"]
[8.2, "o", "\u001b[38;5;245m 33 в”‚\u001b[0m profile = ds[\u001b[38;5;186m\"B04\"\u001b[0m].odc.geobox.crs\r\n"]
[8.3, "o", "\u001b[38;5;245m 34 в”‚\u001b[0m \u001b[38;5;203mwith\u001b[0m rasterio.open(\r\n"]
[8.4, "o", "\u001b[38;5;245m 35 в”‚\u001b[0m     \u001b[38;5;186m\"ndvi_austin.tif\"\u001b[0m, \u001b[38;5;186m\"w\"\u001b[0m, driver=\u001b[38;5;186m\"COG\"\u001b[0m,\r\n"]
[8.5, "o", "\u001b[38;5;245m 36 в”‚\u001b[0m     height=ndvi.shape[\u001b[38;5;186m0\u001b[0m], width=ndvi.shape[\u001b[38;5;186m1\u001b[0m],\r\n"]
[8.6, "o", "\u001b[38;5;245m 37 в”‚\u001b[0m     count=\u001b[38;5;186m1\u001b[0m, dtype=\u001b[38;5;186m\"float32\"\u001b[0m,\r\n"]
[8.7, "o", "\u001b[38;5;245m 38 в”‚\u001b[0m     crs=ds.odc.crs, transform=ds.odc.transform,\r\n"]
[8.8, "o", "\u001b[38;5;245m 39 в”‚\u001b[0m ) \u001b[38;5;203mas\u001b[0m dst:\r\n"]
[8.9, "o", "\u001b[38;5;245m 40 в”‚\u001b[0m     dst.write(ndvi, \u001b[38;5;186m1\u001b[0m)\r\n"]
[9.0, "o", "\u001b[38;5;245m 41 в”‚\u001b[0m\r\n"]
[9.1, "o", "\u001b[38;5;245m 42 в”‚\u001b[0m print(\u001b[38;5;186mf\"Saved NDVI COG: {ndvi.shape}, range [{ndvi.min():.2f}, {ndvi.max():.2f}]\"\u001b[0m)\r\n"]
[9.5, "o", "\r\n"]
[9.8, "o", "\u001b[1;36mв”Њв”Ђ\u001b[0m Running the script...\r\n"]
[9.9, "o", "\u001b[1;36mв””в”Ђ\u001b[0m\r\n\r\n"]
[10.2, "o", "\u001b[1;33m  Bash\u001b[0m python ndvi_austin.py\r\n\r\n"]
[10.8, "o", "  Searching Planetary Computer... "]
[11.4, "o", "found \u001b[1;32m7 scenes\u001b[0m\r\n"]
[12.0, "o", "  Loading B04, B08 at 10m... "]
[13.0, "o", "\u001b[1;32mdone\u001b[0m (150x166 px)\r\n"]
[13.5, "o", "  Computing NDVI... "]
[13.8, "o", "\u001b[1;32mdone\u001b[0m\r\n"]
[14.2, "o", "  Saved NDVI COG: (150, 166), range [-0.12, 0.89]\r\n"]
[14.5, "o", "\r\n"]
[14.8, "o", "\u001b[1;32mвњ“\u001b[0m \u001b[1mndvi_austin.tif\u001b[0m written вЂ” 97 KB Cloud-Optimized GeoTIFF\r\n"]
[15.3, "o", "\r\n"]
[15.5, "o", "\u001b[1;36mв”Њв”Ђ\u001b[0m Done. The NDVI COG covers UT Austin campus at 10m resolution.\r\n"]
[15.6, "o", "\u001b[1;36mв”‚\u001b[0m  Values range from -0.12 (water/shadow) to 0.89 (dense vegetation).\r\n"]
[15.7, "o", "\u001b[1;36mв”‚\u001b[0m  The file is cloud-optimized вЂ” you can serve it directly from S3.\r\n"]
[15.8, "o", "\u001b[1;36mв””в”Ђ\u001b[0m\r\n"]
